{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "launch-qemu",
            "type": "shell",
            "command": "qemu-system-i386",
            "args": [
                "-m", "128M",
                "-s", "-S",
                "-drive", "file=${workspaceFolder}/build/disk.img,index=0,media=disk,format=raw"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            },
            "dependsOn": "build"
        }
    ]
}
